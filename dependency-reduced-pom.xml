<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>net.eqozqq</groupId>
  <artifactId>NostalgiaLauncherDesktop</artifactId>
  <name>NostalgiaLauncherDesktop</name>
  <version>1.10.1_01_01</version>
  <description>Minecraft Pocket Edition Alpha Launcher</description>
  <build>
    <sourceDirectory>src/main/java</sourceDirectory>
    <finalName>nld</finalName>
    <plugins>
      <plugin>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.11.0</version>
        <configuration>
          <source>17</source>
          <target>17</target>
          <encoding>UTF-8</encoding>
        </configuration>
      </plugin>
      <plugin>
        <artifactId>maven-resources-plugin</artifactId>
        <version>3.3.1</version>
        <configuration>
          <encoding>UTF-8</encoding>
        </configuration>
      </plugin>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.5.1</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <outputFile>${project.build.directory}/jpackage-input/${project.build.finalName}.jar</outputFile>
              <transformers>
                <transformer>
                  <mainClass>net.eqozqq.nostalgialauncherdesktop.NostalgiaLauncherDesktop</mainClass>
                </transformer>
              </transformers>
              <artifactSet>
                <includes>
                  <include>*:*</include>
                </includes>
              </artifactSet>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.panteleyev</groupId>
        <artifactId>jpackage-maven-plugin</artifactId>
        <version>1.6.0</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>jpackage</goal>
            </goals>
            <configuration>
              <name>NostalgiaLauncherDesktop</name>
              <appVersion>${project.version}</appVersion>
              <vendor>net.eqozqq</vendor>
              <destination>target/dist</destination>
              <input>${project.build.directory}/jpackage-input</input>
              <mainJar>${project.build.finalName}.jar</mainJar>
              <mainClass>${main.class}</mainClass>
              <javaOptions>
                <option>-Dfile.encoding=UTF-8</option>
              </javaOptions>
              <type>${jpackage.type}</type>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
  <repositories>
    <repository>
      <id>firstdark-releases</id>
      <url>https://maven.firstdark.dev/releases</url>
    </repository>
  </repositories>
  <properties>
    <maven.compiler.target>17</maven.compiler.target>
    <jpackage.type>APP_IMAGE</jpackage.type>
    <main.class>net.eqozqq.nostalgialauncherdesktop.NostalgiaLauncherDesktop</main.class>
    <maven.compiler.source>17</maven.compiler.source>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
  </properties>
</project>
